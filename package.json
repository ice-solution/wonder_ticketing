{
  "name": "wonder-ticketing",
  "version": "1.0.0",
  "description": "Wonder Payment 自助活動售票 SaaS 平台",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/_core/index.ts",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client && tsc",
    "start": "NODE_ENV=production node dist/server/_core/index.js",
    "db:reset": "tsx server/db/reset.ts",
    "db:seed": "tsx server/db/seed.ts",
    "db:bootstrap": "tsx server/db/bootstrap.ts",
    "seed": "tsx server/db/seed.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:fresh": "npm run db:bootstrap && playwright test",
    "wonder:test": "tsx scripts/test-wonder-payment.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1073.0",
    "@trpc/server": "^11.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "nanoid": "^5.0.9",
    "superjson": "^2.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
